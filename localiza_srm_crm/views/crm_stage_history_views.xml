<odoo>
    <record id="view_localiza_crm_stage_history_list" model="ir.ui.view">
        <field name="name">localiza.crm.stage.history.list</field>
        <field name="model">localiza.crm.stage.history</field>
        <field name="arch" type="xml">
            <list string="Historial de fases" create="0" edit="0">
                <field name="lead_id"/>
                <field name="previous_stage_id"/>
                <field name="new_stage_id"/>
                <field name="change_date"/>
                <field name="user_id"/>
                <field name="expected_revenue" sum="Ingreso esperado"/>
                <field name="weighted_revenue" sum="Importe ponderado"/>
                <field name="probability"/>
                <field name="days_in_previous_stage" sum="Días"/>
            </list>
        </field>
    </record>

    <record id="view_localiza_crm_stage_history_form" model="ir.ui.view">
        <field name="name">localiza.crm.stage.history.form</field>
        <field name="model">localiza.crm.stage.history</field>
        <field name="arch" type="xml">
            <form string="Historial de fases" create="0" edit="0">
                <sheet>
                    <group>
                        <field name="lead_id"/>
                        <field name="previous_stage_id"/>
                        <field name="new_stage_id"/>
                        <field name="change_date"/>
                        <field name="user_id"/>
                        <field name="expected_revenue"/>
                        <field name="weighted_revenue"/>
                        <field name="probability"/>
                        <field name="days_in_previous_stage"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_localiza_crm_stage_history_search" model="ir.ui.view">
        <field name="name">localiza.crm.stage.history.search</field>
        <field name="model">localiza.crm.stage.history</field>
        <field name="arch" type="xml">
            <search string="Historial de fases">
                <field name="lead_id"/>
                <field name="new_stage_id"/>
                <field name="user_id"/>
                <filter name="group_stage" string="Etapa" context="{'group_by': 'new_stage_id'}"/>
                <filter name="group_user" string="Usuario" context="{'group_by': 'user_id'}"/>
                <filter name="group_month" string="Mes" context="{'group_by': 'change_date:month'}"/>
            </search>
        </field>
    </record>

    <record id="action_localiza_crm_stage_history" model="ir.actions.act_window">
        <field name="name">Historial de fases</field>
        <field name="res_model">localiza.crm.stage.history</field>
        <field name="view_mode">list,pivot,graph,form</field>
        <field name="search_view_id" ref="view_localiza_crm_stage_history_search"/>
    </record>
</odoo>
