<odoo>
    <record id="view_localiza_mail_activity_list" model="ir.ui.view">
        <field name="name">mail.activity.localiza.list</field>
        <field name="model">mail.activity</field>
        <field name="arch" type="xml">
            <list string="Actividades Localiza" create="1" edit="1">
                <field name="date_deadline" string="Fecha límite"/>
                <field name="summary" string="Asunto"/>
                <field name="localiza_owner"/>
                <field name="localiza_state"/>
                <field name="localiza_priority"/>
                <field name="activity_type_id"/>
                <field name="user_id"/>
                <field name="res_model"/>
            </list>
        </field>
    </record>

    <record id="view_localiza_mail_activity_form" model="ir.ui.view">
        <field name="name">mail.activity.localiza.form</field>
        <field name="model">mail.activity</field>
        <field name="arch" type="xml">
            <form string="Tarea Localiza">
                <sheet>
                    <group>
                        <group>
                            <field name="summary" required="1"/>
                            <field name="date_deadline" required="1"/>
                            <field name="activity_type_id" required="1"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="localiza_owner"/>
                            <field name="localiza_state"/>
                            <field name="localiza_priority"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" nolabel="1" placeholder="Notas de la tarea"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_localiza_mail_activity_search" model="ir.ui.view">
        <field name="name">mail.activity.localiza.search</field>
        <field name="model">mail.activity</field>
        <field name="arch" type="xml">
            <search string="Actividades Localiza">
                <field name="summary"/>
                <field name="user_id"/>
                <field name="localiza_owner"/>
                <filter name="today" string="Hoy" domain="[('date_deadline','=', context_today())]"/>
                <filter name="overdue" string="Vencidas" domain="[('date_deadline','&lt;', context_today())]"/>
                <filter name="pending" string="Pendientes" domain="[('date_deadline','&gt;=', context_today())]"/>
                <separator/>
                <filter name="group_user" string="Usuario" context="{'group_by': 'user_id'}"/>
                <filter name="group_owner" string="Titular Localiza" context="{'group_by': 'localiza_owner'}"/>
                <filter name="group_deadline" string="Fecha límite" context="{'group_by': 'date_deadline'}"/>
            </search>
        </field>
    </record>

    <record id="action_localiza_activities_today" model="ir.actions.act_window">
        <field name="name">Actividades de hoy</field>
        <field name="res_model">mail.activity</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_today': 1}</field>
        <field name="search_view_id" ref="view_localiza_mail_activity_search"/>
        <field name="views" eval="[(ref('view_localiza_mail_activity_list'), 'list'), (ref('view_localiza_mail_activity_form'), 'form')]"/>
    </record>

    <record id="action_localiza_activities_overdue" model="ir.actions.act_window">
        <field name="name">Actividades vencidas</field>
        <field name="res_model">mail.activity</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_overdue': 1}</field>
        <field name="search_view_id" ref="view_localiza_mail_activity_search"/>
        <field name="views" eval="[(ref('view_localiza_mail_activity_list'), 'list'), (ref('view_localiza_mail_activity_form'), 'form')]"/>
    </record>

    <record id="action_localiza_activities_pending" model="ir.actions.act_window">
        <field name="name">Actividades pendientes</field>
        <field name="res_model">mail.activity</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_pending': 1}</field>
        <field name="search_view_id" ref="view_localiza_mail_activity_search"/>
        <field name="views" eval="[(ref('view_localiza_mail_activity_list'), 'list'), (ref('view_localiza_mail_activity_form'), 'form')]"/>
    </record>
</odoo>
