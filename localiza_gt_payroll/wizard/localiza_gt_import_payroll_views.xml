<odoo>
    <record id="view_localiza_gt_import_payroll_wizard_form" model="ir.ui.view">
        <field name="name">localiza.gt.import.payroll.wizard.form</field>
        <field name="model">localiza.gt.import.payroll.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar planilla Localiza">
                <group>
                    <field name="batch_id"/>
                    <field name="sheet_name" placeholder="1ra quincena"/>
                    <field name="file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                </group>
                <footer>
                    <button name="action_import" type="object" string="Importar" class="btn-primary"/>
                    <button string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_localiza_gt_import_payroll_wizard" model="ir.actions.act_window">
        <field name="name">Importar planilla Excel</field>
        <field name="res_model">localiza.gt.import.payroll.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
    <menuitem id="menu_localiza_gt_import_payroll" name="Importar Excel" parent="menu_localiza_gt_payroll_root" action="action_localiza_gt_import_payroll_wizard" sequence="30"/>
</odoo>
