<odoo>
    <record id="view_localiza_asignacion_list" model="ir.ui.view">
        <field name="name">localiza.asignacion.list</field>
        <field name="model">localiza.asignacion</field>
        <field name="arch" type="xml">
            <list string="Asignaciones" decoration-muted="estado == 'cancelado'" decoration-success="estado == 'confirmado'">
                <field name="name"/>
                <field name="fecha"/>
                <field name="tipo"/>
                <field name="receptor"/>
                <field name="puesto_id"/>
                <field name="articulo_id"/>
                <field name="gps_id"/>
                <field name="cantidad"/>
                <field name="estado"/>
            </list>
        </field>
    </record>
    <record id="view_localiza_asignacion_form" model="ir.ui.view">
        <field name="name">localiza.asignacion.form</field>
        <field name="model">localiza.asignacion</field>
        <field name="arch" type="xml">
            <form string="Asignacion">
                <header>
                    <button name="action_confirmar" type="object" string="Confirmar" class="btn-primary" invisible="estado != 'borrador'"/>
                    <button name="action_cancelar" type="object" string="Cancelar" invisible="estado == 'cancelado'"/>
                    <field name="estado" widget="statusbar" statusbar_visible="borrador,confirmado,cancelado"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="fecha"/>
                            <field name="tipo"/>
                            <field name="receptor"/>
                            <field name="dpi"/>
                            <field name="employee_id"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="puesto_id"/>
                            <field name="articulo_id"/>
                            <field name="gps_id"/>
                            <field name="product_id"/>
                            <field name="cantidad"/>
                            <field name="talla"/>
                            <field name="serie"/>
                        </group>
                    </group>
                    <group><field name="observacion"/></group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_localiza_asignacion" model="ir.actions.act_window">
        <field name="name">Asignaciones</field>
        <field name="res_model">localiza.asignacion</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
