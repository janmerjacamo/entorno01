<odoo>
    <record id="view_localiza_articulo_list" model="ir.ui.view">
        <field name="name">localiza.articulo.list</field>
        <field name="model">localiza.articulo</field>
        <field name="arch" type="xml">
            <list string="Articulos" decoration-danger="estado in ('perdido','danado','baja')" decoration-success="estado == 'bodega'">
                <field name="codigo"/>
                <field name="name"/>
                <field name="categoria"/>
                <field name="subcategoria"/>
                <field name="talla"/>
                <field name="cantidad"/>
                <field name="estado"/>
                <field name="puesto_id"/>
                <field name="ubicacion_texto"/>
                <field name="costo"/>
            </list>
        </field>
    </record>
    <record id="view_localiza_articulo_form" model="ir.ui.view">
        <field name="name">localiza.articulo.form</field>
        <field name="model">localiza.articulo</field>
        <field name="arch" type="xml">
            <form string="Articulo Operativo">
                <header>
                    <button name="action_create_product" type="object" string="Crear producto Odoo" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="codigo"/>
                            <field name="categoria"/>
                            <field name="subcategoria"/>
                            <field name="talla"/>
                            <field name="cantidad"/>
                            <field name="estado"/>
                        </group>
                        <group>
                            <field name="product_id"/>
                            <field name="serie"/>
                            <field name="factura"/>
                            <field name="fecha_ingreso"/>
                            <field name="proveedor"/>
                            <field name="costo"/>
                        </group>
                    </group>
                    <group>
                        <field name="puesto_id"/>
                        <field name="ubicacion_texto"/>
                    </group>
                    <group><field name="notes"/></group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_localiza_articulo" model="ir.actions.act_window">
        <field name="name">Articulos Operativos</field>
        <field name="res_model">localiza.articulo</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
