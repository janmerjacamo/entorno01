<odoo>
    <record id="view_product_template_form_localiza" model="ir.ui.view">
        <field name="name">product.template.form.localiza</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Localiza Bodega Operativa">
                    <field name="x_localiza_operativo"/>
                    <field name="x_localiza_tipo"/>
                    <field name="x_localiza_talla"/>
                    <field name="x_localiza_codigo_excel"/>
                    <field name="x_localiza_ubicacion_texto"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
