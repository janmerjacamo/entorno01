<odoo>
    <record id="view_localiza_puesto_list" model="ir.ui.view">
        <field name="name">localiza.puesto.list</field>
        <field name="model">localiza.puesto</field>
        <field name="arch" type="xml">
            <list string="Puestos">
                <field name="name"/>
                <field name="code"/>
                <field name="tipo"/>
                <field name="partner_id"/>
                <field name="department"/>
                <field name="agent_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_localiza_puesto_form" model="ir.ui.view">
        <field name="name">localiza.puesto.form</field>
        <field name="model">localiza.puesto</field>
        <field name="arch" type="xml">
            <form string="Puesto">
                <sheet>
                    <div class="oe_title"><h1><field name="name" placeholder="Nombre del puesto"/></h1></div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="tipo"/>
                            <field name="partner_id"/>
                            <field name="responsible_id"/>
                        </group>
                        <group>
                            <field name="address"/>
                            <field name="department"/>
                            <field name="agent_count"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_localiza_puesto" model="ir.actions.act_window">
        <field name="name">Puestos</field>
        <field name="res_model">localiza.puesto</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
