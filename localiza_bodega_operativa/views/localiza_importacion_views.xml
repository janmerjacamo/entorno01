<odoo>
    <record id="view_localiza_importacion_linea_list" model="ir.ui.view">
        <field name="name">localiza.importacion.linea.list</field>
        <field name="model">localiza.importacion.linea</field>
        <field name="arch" type="xml">
            <list string="Lineas importadas" decoration-danger="estado == 'error'" decoration-success="estado == 'creado'">
                <field name="estado"/>
                <field name="tipo"/>
                <field name="codigo"/>
                <field name="nombre"/>
                <field name="subcategoria"/>
                <field name="talla"/>
                <field name="imei"/>
                <field name="modelo"/>
                <field name="cliente"/>
                <field name="error"/>
            </list>
        </field>
    </record>
    <record id="view_localiza_importacion_list" model="ir.ui.view">
        <field name="name">localiza.importacion.list</field>
        <field name="model">localiza.importacion</field>
        <field name="arch" type="xml">
            <list string="Importaciones">
                <field name="name"/>
                <field name="tipo"/>
                <field name="archivo_nombre"/>
                <field name="hoja"/>
                <field name="state"/>
                <field name="total_lineas"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>
    <record id="view_localiza_importacion_form" model="ir.ui.view">
        <field name="name">localiza.importacion.form</field>
        <field name="model">localiza.importacion</field>
        <field name="arch" type="xml">
            <form string="Importacion Excel">
                <header>
                    <button name="action_procesar" type="object" string="Leer Excel" class="btn-primary"/>
                    <button name="action_crear_registros" type="object" string="Crear registros"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,processed,error"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="tipo"/>
                            <field name="hoja"/>
                            <field name="archivo" filename="archivo_nombre"/>
                            <field name="archivo_nombre" invisible="1"/>
                        </group>
                        <group>
                            <field name="total_lineas" readonly="1"/>
                            <field name="errores" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lineas leidas">
                            <field name="line_ids" readonly="1">
                                <list>
                                    <field name="estado"/>
                                    <field name="tipo"/>
                                    <field name="codigo"/>
                                    <field name="nombre"/>
                                    <field name="subcategoria"/>
                                    <field name="talla"/>
                                    <field name="imei"/>
                                    <field name="modelo"/>
                                    <field name="cliente"/>
                                    <field name="error"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_localiza_importacion" model="ir.actions.act_window">
        <field name="name">Importaciones Excel</field>
        <field name="res_model">localiza.importacion</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
