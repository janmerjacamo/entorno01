<odoo>
    <record id="view_localiza_gps_list" model="ir.ui.view">
        <field name="name">localiza.gps.list</field>
        <field name="model">localiza.gps</field>
        <field name="arch" type="xml">
            <list string="GPS" decoration-success="estado == 'bodega'" decoration-info="estado == 'instalado'">
                <field name="imei"/>
                <field name="modelo"/>
                <field name="marca"/>
                <field name="estado"/>
                <field name="cliente"/>
                <field name="placa"/>
                <field name="puesto_id"/>
                <field name="factura"/>
                <field name="precio"/>
            </list>
        </field>
    </record>
    <record id="view_localiza_gps_form" model="ir.ui.view">
        <field name="name">localiza.gps.form</field>
        <field name="model">localiza.gps</field>
        <field name="arch" type="xml">
            <form string="GPS">
                <sheet>
                    <div class="oe_title"><h1><field name="imei" placeholder="IMEI"/></h1></div>
                    <group>
                        <group>
                            <field name="modelo"/>
                            <field name="marca"/>
                            <field name="serie"/>
                            <field name="estado"/>
                            <field name="product_id"/>
                        </group>
                        <group>
                            <field name="fecha_compra"/>
                            <field name="proveedor"/>
                            <field name="factura"/>
                            <field name="precio"/>
                            <field name="iva"/>
                        </group>
                    </group>
                    <group string="Asignacion actual">
                        <field name="cliente"/>
                        <field name="partner_id"/>
                        <field name="placa"/>
                        <field name="puesto_id"/>
                    </group>
                    <group><field name="notes"/></group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_localiza_gps" model="ir.actions.act_window">
        <field name="name">GPS</field>
        <field name="res_model">localiza.gps</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
